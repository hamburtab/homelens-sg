.DS_Store
.env
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage

# Reproducible outputs generated by the pipeline
data/raw/*.csv
data/raw/official_layers/*.geojson
data/processed/*.csv
data/processed/geocode_cache.json
artifacts/models/*.joblib
artifacts/metrics/*.json
artifacts/manifests/*.json
artifacts/figures/*.png

# Keep directory structure in Git
!data/raw/.gitkeep
!data/processed/.gitkeep
!artifacts/models/.gitkeep
!artifacts/metrics/.gitkeep
!artifacts/manifests/.gitkeep
!artifacts/figures/.gitkeep
